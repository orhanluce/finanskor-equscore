# EquScore — frontend (VITE_*) environment variables.
# Copy to .env and fill in. VITE_* vars are baked into the build at build time.
# The Supabase URL/anon key are public (RLS-protected).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Product analytics (PostHog). Leave blank to disable — the app runs fine without it
# and posthog-js is never downloaded. Create a free project at posthog.com.
VITE_POSTHOG_KEY=
# EU cloud by default; use https://us.i.posthog.com for the US region.
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Production error tracking (Sentry). Leave blank to disable. DSN from sentry.io.
VITE_SENTRY_DSN=
